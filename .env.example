# ──────────────────────────────────────────────────────────────────────────────
# CMND by DOO — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (Frontend) ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# ── SMTP Email (Supabase Edge Function secrets) ───────────────────────────────
# Set these via:  supabase secrets set SMTP_HOST=smtp.zoho.com  (etc.)
#
# SMTP_HOST         — Your SMTP server hostname
#                     Examples:
#                       smtp.gmail.com      (Gmail)
#                       smtp.zoho.com       (Zoho)
#                       mail.privateemail.com (Namecheap)
#                       smtp.office365.com  (Microsoft 365)
#
SMTP_HOST=smtp.zoho.com

# SMTP_PORT         — 587 for STARTTLS (recommended), 465 for SSL
SMTP_PORT=587

# SMTP_USER         — The full email address you send FROM
SMTP_USER=notifications@doo.ooo

# SMTP_PASS         — App password (Gmail/Zoho) or your email password
#                     For Gmail: generate at https://myaccount.google.com/apppasswords
#                     For Zoho:  generate at https://accounts.zoho.com/home#security
SMTP_PASS=your-app-password-here

# SMTP_FROM_NAME    — Display name shown in the recipient's inbox
SMTP_FROM_NAME=CMND by DOO

# ── App URL (used in email footers & CTA buttons) ────────────────────────────
SITE_URL=https://cmnd.doo.ooo
